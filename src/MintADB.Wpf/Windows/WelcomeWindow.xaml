<Window x:Class="MintADB.Wpf.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource WelcomeTitle}" Width="600" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1a1a2e" Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="MintADB" FontSize="28" FontWeight="Bold" Foreground="#00C9A7"/>
            <TextBlock Text="{DynamicResource QuickGuide}" FontSize="14" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Step 1 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="#000"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource ConnectPhone}" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource ConnectPhoneDesc}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 2 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="#000"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource EnableUSBDebugging}" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource EnableUSBDebuggingDesc}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 3 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="#000"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource AllowUSBDebugging}" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource AllowUSBDebuggingDesc}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tips -->
                <Border Background="#2A2418" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource UsefulTips}" FontSize="14" FontWeight="SemiBold" Foreground="#FFD060"/>
                        <TextBlock Text="{DynamicResource Tip1}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <TextBlock Text="{DynamicResource Tip2}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock Text="{DynamicResource Tip3}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock Text="{DynamicResource Tip4}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock Text="{DynamicResource Tip5}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock Text="{DynamicResource Tip6}" Foreground="#aaa" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <CheckBox x:Name="DontShowAgain" Content="{DynamicResource DontShowAgain}"
                      VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#aaa"/>
            <Button Content="{DynamicResource GetStarted}" Click="Start_Click" MinWidth="100" Padding="16,8"
                    FontSize="14" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#00C9A7"/>
                        <Setter Property="Foreground" Value="#000"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
