<Window x:Class="MintADB.Wpf.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MintADB - Hướng dẫn sử dụng" Width="600" Height="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1a1a2e" Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="MintADB" FontSize="28" FontWeight="Bold" Foreground="#00C9A7"/>
            <TextBlock Text="Hướng dẫn sử dụng nhanh" FontSize="14" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Step 1 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="#000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Kết nối điện thoại" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="• Bật USB Debugging trong Cài đặt → Tùy chọn nhà phát triển" Foreground="#aaa" TextWrapping="Wrap"/>
                            <TextBlock Text="• Cắm cáp USB và chọn 'Cho phép gỡ lỗi'" Foreground="#aaa" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 2 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="#000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Tab Tối ưu (Xiaomi China)" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="• Quét ROM → Chọn app → Fix thông báo / Cấp quyền" Foreground="#aaa" TextWrapping="Wrap"/>
                            <TextBlock Text="• Full Optimize: Tắt hạn chế + Mở khóa + Đổi region" Foreground="#aaa" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 3 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="#000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Tab Công cụ" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="• Cơ bản: Cài APK, Push/Pull file, Reboot" Foreground="#aaa" TextWrapping="Wrap"/>
                            <TextBlock Text="• Hệ thống: Xem Pin, Màn hình, CPU, RAM, Storage" Foreground="#aaa" TextWrapping="Wrap"/>
                            <TextBlock Text="• Tinh chỉnh: DPI, Animation, Hz, Font" Foreground="#aaa" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Step 4 -->
                <Border Background="#16213e" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#00C9A7" VerticalAlignment="Top">
                            <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="#000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Fastboot" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="• Flash ROM, Unlock/Lock bootloader" Foreground="#aaa" TextWrapping="Wrap"/>
                            <TextBlock Text="• Boot tạm thời, Factory reset" Foreground="#aaa" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tips -->
                <Border Background="#2A2418" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="💡 Mẹo hữu ích" FontSize="14" FontWeight="SemiBold" Foreground="#FFD060"/>
                        <TextBlock Text="• Luôn backup trước khi flash ROM" Foreground="#aaa" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock Text="• Dùng 'Debloat an toàn' thay vì gỡ thủ công" Foreground="#aaa" TextWrapping="Wrap"/>
                        <TextBlock Text="• Tab Hệ thống xem thông tin chi tiết thiết bị" Foreground="#aaa" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <CheckBox x:Name="DontShowAgain" Content="Không hiển thị lại" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#aaa"/>
            <Button Content="Bắt đầu" Click="Start_Click" MinWidth="100" Padding="16,8" FontSize="14" FontWeight="SemiBold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#00C9A7"/>
                        <Setter Property="Foreground" Value="#000"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
