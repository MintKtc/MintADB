                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock x:Name="StorageInfoText" Text="{DynamicResource TapReadHint}"
                                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                           Foreground="{StaticResource MacBlueBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <UniformGrid Columns="1">
                                    <Button x:Name="BtnLoadStorageInfo" Content="{DynamicResource ReadDisplayInfo}"
                                            Click="LoadStorageInfo_Click" Style="{StaticResource MacToolbarBtn}" MinWidth="150"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- RAM Info -->
                        <TextBlock Text="RAM" Style="{StaticResource MacGroupLabelSafe}"/>
                        <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,12" Padding="12">
