                                </Grid>
                                <TextBlock Text="{DynamicResource PullSavedTo}"
                                           FontSize="10" Foreground="{StaticResource MacSecondaryBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ListRemoteBox" Grid.Column="0" Tag="/sdcard/"/>
