                                    <TextBox x:Name="PushLocalBox" Grid.Column="0" Tag="{StaticResource LocalFilePath}"/>
                                    <Button x:Name="BtnBrowsePush" Grid.Column="1" Content="{DynamicResource ChooseFile}"
                                            Click="BrowsePush_Click" Style="{StaticResource MacToolbarBtn}" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PushRemoteBox" Grid.Column="0" Tag="/sdcard/Download/"/>
                                    <Button x:Name="BtnPush" Grid.Column="1" Content="Push"
                                            Click="Push_Click" Style="{StaticResource MacToolbarBtn}" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PullRemoteBox" Grid.Column="0" Tag="/sdcard/Download/file.txt"/>
                                    <Button x:Name="BtnPull" Grid.Column="1" Content="Pull"
