                            <Run Foreground="#FF6961" FontWeight="SemiBold" Text="đỏ = lỗi"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#FFBF47" FontWeight="SemiBold" Text="vàng = đang chạy"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#7EC8FF" FontWeight="SemiBold" Text="xanh dương = tiêu đề"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#E5E5EA" FontWeight="SemiBold" Text="trắng = log thường"/>
                        </TextBlock>
                        <Border Style="{StaticResource MacTerminalBox}">
