                                    <Run Text=" if pnputil doesn't work, open Device Manager → manually update driver."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource Reboot}" Style="{StaticResource MacGroupLabelDanger}"/>
