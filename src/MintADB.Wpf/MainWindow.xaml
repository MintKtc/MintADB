                                </UniformGrid>
                                <TextBlock Text="Quick flash (uses selected file above)" FontSize="10"
                                           Foreground="{StaticResource MacSecondaryBrush}" Margin="0,0,0,6"/>
                                <UniformGrid Columns="5">
                                    <Button x:Name="BtnFastbootFlashBoot" Content="boot"
                                            Click="FastbootFlashBoot_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnFastbootFlashRecovery" Content="recovery"
                                            Click="FastbootFlashRecovery_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnFastbootFlashVendorBoot" Content="vendor_boot"
                                            Click="FastbootFlashVendorBoot_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnFastbootFlashVbmeta" Content="vbmeta"
                                            Click="FastbootFlashVbmeta_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnFastbootFlashVbmetaDisable" Content="vbmeta (no verify)"
                                            Click="FastbootFlashVbmetaDisable_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"
                                            ToolTip="Flash vbmeta with --disable-verity --disable-verification"/>
                                </UniformGrid>
                                <TextBlock FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource MacSecondaryBrush}">
                                    <Run Text="vbmeta (no verify)" FontWeight="SemiBold"/>
                                    <Run Text=" — disables verified boot, required for custom ROM."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Device Info -->
                        <TextBlock Text="{DynamicResource DeviceInfo}" Style="{StaticResource MacGroupLabelInfo}"/>
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Read detailed device info in Fastboot mode."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <UniformGrid Columns="2">
                                    <Button x:Name="BtnFastbootGetVarAll" Content="Get all variables"
                                            Click="FastbootGetVarAll_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnFastbootOemDeviceInfo" Content="OEM device info"
                                            Click="FastbootOemDeviceInfo_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- ── Flash ROM (MiFlash-style) ── -->
                        <TextBlock Text="Flash ROM (MiFlash)" Style="{StaticResource MacGroupLabelDanger}"/>
                        <Border Style="{StaticResource MacGroupBoxDanger}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Select extracted ROM folder (contains flash_all.bat / flash_all_except_storage.bat / images/)"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FastbootRomBox" Grid.Column="0" Tag="ROM folder path"/>
                                    <Button x:Name="BtnBrowseFastbootRom" Grid.Column="1" Content="Choose ROM"
                                            Click="BrowseFastbootRom_Click" Style="{StaticResource MacToolbarBtn}"
                                            Margin="8,0,4,0" MinWidth="90"/>
                                    <Button x:Name="BtnFastbootAutoDetect" Grid.Column="2" Content="Auto detect"
                                            Click="FastbootAutoDetectSerial_Click" Style="{StaticResource MacToolbarBtn}"
                                            MinWidth="90"/>
                                </Grid>

                                <!-- ROM Info -->
                                <TextBlock x:Name="FastbootRomStatusText" FontSize="11" Margin="0,0,0,4"
                                           Foreground="{StaticResource MacSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock x:Name="FastbootRomInfoText" FontSize="10" Margin="0,0,0,10"
                                           Foreground="{StaticResource MacBlueBrush}" TextWrapping="Wrap"/>

                                <!-- Flash options -->
                                <TextBlock Text="Select flash mode:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <UniformGrid Columns="3" Margin="0,0,0,10">
                                    <Button x:Name="BtnFastbootFlashRom" Content="Flash all (wipe)"
                                            Click="FastbootFlashRom_Click" Style="{StaticResource MacBtnDestructive}" Margin="0,0,4,0"
                                            ToolTip="flash_all.bat — erases all data"/>
                                    <Button x:Name="BtnFastbootFlashRomKeep" Content="Flash all (keep data)"
                                            Click="FastbootFlashRomKeep_Click" Style="{StaticResource MacBtnSecondary}" Margin="0,0,4,0"
                                            ToolTip="flash_all_except_storage.bat — keeps userdata"/>
                                    <Button x:Name="BtnFastbootFlashRomCurrentSlot" Content="Flash current slot"
                                            Click="FastbootFlashRomCurrentSlot_Click" Style="{StaticResource MacBtnSecondary}" Background="#6A1B9A" Margin="4,0,0,0"
                                            ToolTip="flash_current_slot.bat — flash active slot only"/>
                                </UniformGrid>

                                <UniformGrid Columns="3" Margin="0,0,0,10">
                                    <Button x:Name="BtnFastbootFlashRomLock" Content="Flash + Lock"
                                            Click="FastbootFlashRomLock_Click" Style="{StaticResource MacBtnDestructive}" Margin="0,0,4,0"
                                            ToolTip="flash_all_lock.bat — flash and lock bootloader"/>
                                    <Button x:Name="BtnFastbootCancelFlash" Content="Cancel Flash"
                                            Click="CancelFlashRom_Click" Style="{StaticResource MacBtnSecondary}" Background="#E65100" Margin="0,0,4,0"
                                            ToolTip="Stop flash in progress"/>
                                    <Button x:Name="BtnFastbootFlashRomOpenDir" Content="Open ROM Folder"
                                            Click="FastbootFlashRomOpenDir_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>

                                <TextBlock FontSize="10" Foreground="{StaticResource MacSecondaryBrush}" TextWrapping="Wrap">
                                    <Run Text="Note:" FontWeight="SemiBold"/>
                                    <Run Text=" Flash current slot only flashes active partition. Flash + Lock will lock bootloader."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        </StackPanel>

                        <!-- ── Advanced ── -->
                        <StackPanel x:Name="ToolPageAdvanced" Visibility="Collapsed">

                        <TextBlock Text="Device Spoof &amp; Unlock FPS" Style="{StaticResource MacGroupLabelWarn}"/>
                        <Border Style="{StaticResource MacGroupBoxWarn}" Margin="0,0,0,16" Padding="0" ClipToBounds="True"
                                CornerRadius="{StaticResource MacRadiusGroup}">
                            <StackPanel>
                                <Border Background="#2A2418" Padding="14,12" Style="{StaticResource MacPanelHeader}">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource DeviceSpoofHeader}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="{DynamicResource DeviceSpoofHeaderDesc}"
                                                   FontSize="10" Foreground="#E65100" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="DeviceSpoofCapText" Text="{DynamicResource CheckingCapabilities}"
                                                   FontSize="10" Foreground="{StaticResource MacSecondaryBrush}"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource FlagshipProfile}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="DeviceSpoofPreset" Margin="0,0,0,6"
                                                  MaxDropDownHeight="320"
                                                  SelectionChanged="DeviceSpoofPreset_SelectionChanged"/>
                                        <TextBlock x:Name="DeviceSpoofProfileHint" FontSize="10"
                                                   Foreground="{StaticResource MacSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                                        <CheckBox x:Name="DeviceSpoofApplyProps" Content="{DynamicResource FakeDeviceProps}"
                                                  IsChecked="True" Margin="0,0,0,4"/>
                                        <CheckBox x:Name="DeviceSpoofApplyFps" Content="{DynamicResource UnlockFpsHz}"
                                                  IsChecked="True" Margin="0,0,0,8"/>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{DynamicResource TargetHz}" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="DeviceSpoofHzPreset" Grid.Column="1" SelectedIndex="2">
                                                <ComboBoxItem Content="60 Hz"/>
                                                <ComboBoxItem Content="90 Hz"/>
                                                <ComboBoxItem Content="120 Hz"/>
                                                <ComboBoxItem Content="144 Hz"/>
                                            </ComboBox>
                                        </Grid>
                                        <CheckBox x:Name="DeviceSpoofDisableBooster" Content="{DynamicResource DisableGameBooster}"
                                                  IsChecked="True" Margin="0,0,0,10"/>

                                        <WrapPanel Margin="0,0,0,8">
                                            <Button x:Name="BtnCheckDeviceSpoofCap" Content="{DynamicResource CheckLocale}"
                                                    Click="CheckDeviceSpoofCap_Click"
                                                    Style="{StaticResource MacToolbarBtn}"/>
                                            <Button x:Name="BtnReadDeviceSpoofInfo" Content="{DynamicResource ReadCurrentDevice}"
                                                    Click="ReadDeviceSpoofInfo_Click"
                                                    Style="{StaticResource MacToolbarBtn}"/>
                                            <Button x:Name="BtnApplyDeviceSpoof" Content="{StaticResource Apply}"
                                                    Click="ApplyDeviceSpoof_Click"
                                                    Style="{StaticResource MacBtnPrimary}"/>
                                            <Button x:Name="BtnRestoreDeviceSpoof" Content="{DynamicResource Restore}"
                                                    Click="RestoreDeviceSpoof_Click"
                                                    Style="{StaticResource MacBtnSecondary}" Margin="0"/>
                                        </WrapPanel>

                                        <TextBox x:Name="DeviceSpoofInfoText" IsReadOnly="True" TextWrapping="Wrap"
                                                 MinHeight="72" MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                                 Text="Tap «Read current device» to view ro.product.*"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Shizuku" Style="{StaticResource MacGroupLabelInfo}"/>
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Shizuku allows apps to run system commands via ADB — install app and open once before starting."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <TextBlock x:Name="ShizukuStatusText" Text="Not checked"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnCheckShizuku" Content="{DynamicResource CheckLocale}"
                                            Click="CheckShizuku_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnStartShizuku" Content="{DynamicResource StartShizuku}"
                                            Click="StartShizuku_Click" Style="{StaticResource MacBtnPrimary}"/>
                                    <Button x:Name="BtnOpenShizuku" Content="Open Shizuku app"
                                            Click="OpenShizuku_Click" Style="{StaticResource MacToolBtn}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Shizuku Permissions" Style="{StaticResource MacGroupLabelWarn}"/>
                        <Border Style="{StaticResource MacGroupBoxWarn}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Select app in Optimize tab, or enter package + permission to Grant/Revoke."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button x:Name="BtnGrantShizukuApi" Content="Grant Shizuku API"
                                            Click="GrantShizukuApi_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnGrantAllShizukuPerms" Content="Grant All (privileged)"
                                            Click="GrantAllShizukuPerms_Click" Style="{StaticResource MacBtnPrimary}"/>
                                </WrapPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ShizukuPermPreset" SelectedIndex="0" Margin="0,0,8,0">
                                        <ComboBoxItem Content="Shizuku API Permission" Tag="moe.shizuku.manager.permission.API_V23"/>
                                        <ComboBoxItem Content="WRITE_SECURE_SETTINGS" Tag="android.permission.WRITE_SECURE_SETTINGS"/>
                                        <ComboBoxItem Content="WRITE_SETTINGS" Tag="android.permission.WRITE_SETTINGS"/>
                                        <ComboBoxItem Content="DUMP" Tag="android.permission.DUMP"/>
                                        <ComboBoxItem Content="READ_LOGS" Tag="android.permission.READ_LOGS"/>
                                        <ComboBoxItem Content="POST_NOTIFICATIONS" Tag="android.permission.POST_NOTIFICATIONS"/>
                                        <ComboBoxItem Content="Skip battery optimization" Tag="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
                                        <ComboBoxItem Content="MANAGE_EXTERNAL_STORAGE" Tag="android.permission.MANAGE_EXTERNAL_STORAGE"/>
                                    </ComboBox>
                                    <TextBox x:Name="ShizukuPermCustomBox" Tag="android.permission.CUSTOM..." Grid.Column="1"/>
                                </Grid>
                                <WrapPanel>
                                    <Button x:Name="BtnGrantShizukuPerm" Content="Grant"
                                            Click="GrantShizukuPerm_Click" Style="{StaticResource MacBtnPrimary}"/>
                                    <Button x:Name="BtnRevokeShizukuPerm" Content="Revoke"
                                            Click="RevokeShizukuPerm_Click" Style="{StaticResource MacBtnDestructive}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Quick AppOps (Shizuku / ADB)" Style="{StaticResource MacGroupLabelSafe}"/>
                        <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,24" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Grant common AppOps for selected app."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- AppOps basic -->
                                <TextBlock Text="Basic:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <UniformGrid Columns="4" Margin="0,0,0,10">
                                    <Button x:Name="BtnShizukuUsageStats" Content="Usage Stats"
                                            Click="GrantShizukuUsageStats_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuOverlay" Content="Overlay"
                                            Click="GrantShizukuOverlay_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuBattery" Content="Battery"
                                            Click="GrantShizukuBattery_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuRunBackground" Content="Background"
                                            Click="GrantShizukuRunBackground_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>

                                <!-- AppOps location & camera -->
                                <TextBlock Text="Location &amp; Camera:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <UniformGrid Columns="4" Margin="0,0,0,10">
                                    <Button x:Name="BtnShizukuNfc" Content="NFC"
                                            Click="GrantShizukuNfc_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuLocation" Content="Coarse Location"
                                            Click="GrantShizukuLocation_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuFineLocation" Content="Fine Location"
                                            Click="GrantShizukuFineLocation_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuCamera" Content="Camera"
                                            Click="GrantShizukuCamera_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>

                                <!-- AppOps other -->
                                <TextBlock Text="Other:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <UniformGrid Columns="2" Margin="0,0,0,10">
                                    <Button x:Name="BtnShizukuContacts" Content="Read Contacts"
                                            Click="GrantShizukuContacts_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnShizukuCustomAppOp" Content="Custom AppOp"
                                            Click="GrantShizukuCustomAppOp_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>

                                <!-- Custom AppOp input -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ShizukuCustomAppOpBox" Grid.Column="0"
                                             Tag="{DynamicResource CustomAppOps}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        </StackPanel>

                        </Grid>
                        </Border>

                        </StackPanel>

                        <!-- Terminal -->
                        <TextBlock Text="Log" Style="{StaticResource MacGroupLabel}"/>
                        <TextBlock Style="{StaticResource MacRiskLegend}" Margin="4,0,0,8">
                            <Run Foreground="#5DD68A" FontWeight="SemiBold" Text="green = OK"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#FF6961" FontWeight="SemiBold" Text="red = error"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#FFBF47" FontWeight="SemiBold" Text="yellow = running"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#7EC8FF" FontWeight="SemiBold" Text="blue = header"/>
                            <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                            <Run Foreground="#E5E5EA" FontWeight="SemiBold" Text="white = normal log"/>
                        </TextBlock>
                        <Border Style="{StaticResource MacTerminalBox}">
                            <Grid ClipToBounds="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="240"/>
                                </Grid.RowDefinitions>
                                <Border Background="#2A2A2A" Style="{StaticResource MacPanelHeader}" ClipToBounds="True"
                                        BorderBrush="#484848" BorderThickness="0,0,0,1">
                                    <Grid Margin="12,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="#0A84FF" Margin="0,0,8,0"/>
                                            <TextBlock Text="Log — MintADB" FontSize="11" FontWeight="Bold"
                                                       Foreground="#7EC8FF"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Content="{DynamicResource ClearHistory}" Click="ClearLog_Click"
                                                Style="{StaticResource MacBtnSecondary}"
                                                FontSize="11" Padding="8,2" Margin="0"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Background="#141416"
                                        Style="{StaticResource MacPanelFooter}" ClipToBounds="True"
                                        BorderBrush="#484848" BorderThickness="0,1,0,0">
                                    <RichTextBox x:Name="LogBox" Style="{StaticResource MacLogBox}"/>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>