                                              IsChecked="True" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="HzLockGpuBoost" Content="Boost GPU performance (force GPU rendering)"
                                              IsChecked="True" Margin="0,0,0,10"/>

                                    <WrapPanel Margin="0,0,0,8">
                                        <Button x:Name="BtnReadHzLock" Content="{DynamicResource ReadHz}"
                                                Click="ReadHzLockStatus_Click"
                                                Style="{StaticResource MacToolbarBtn}"/>
                                        <Button x:Name="BtnApplyHzLock" Content="{DynamicResource ApplyHzLock}"
                                                Click="ApplyHzLock_Click"
                                                Style="{StaticResource MacBtnPrimary}"/>
                                        <Button x:Name="BtnApplySmoothUi" Content="{DynamicResource SmoothUI}"
                                                Click="ApplySmoothUi_Click"
                                                Style="{StaticResource MacBtnSecondary}" Margin="0"/>
                                        <Button x:Name="BtnApplyHzLockFull" Content="{DynamicResource ApplyHzLockFull}"
                                                Click="ApplyHzLockFull_Click"
                                                Style="{StaticResource MacBtnPrimary}"/>
                                        <Button x:Name="BtnRestoreAdaptiveHz" Content="{DynamicResource RestoreAdaptiveHz}"
                                                Click="RestoreAdaptiveHz_Click"
                                                Style="{StaticResource MacBtnSecondary}" Margin="0"/>
                                    </WrapPanel>

                                    <TextBox x:Name="HzLockStatusText" IsReadOnly="True" TextWrapping="Wrap"
