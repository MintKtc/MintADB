                                    <Button x:Name="BtnShizukuBattery" Content="Bỏ qua tối ưu pin"
                                            Click="GrantShizukuBattery_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnShizukuRunBackground" Content="Chạy nền"
                                            Click="GrantShizukuRunBackground_Click" Style="{StaticResource MacToolBtn}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        </StackPanel>

                        </Grid>
                        </Border>

