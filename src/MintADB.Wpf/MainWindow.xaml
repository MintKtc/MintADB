                                <CheckBox x:Name="ScrcpyStayAwake" Content="{DynamicResource KeepScreenOn}"
                                          IsChecked="True" Margin="0,0,0,10"/>
                                <Button x:Name="BtnLaunchScrcpy" Content="{DynamicResource LaunchScrcpy}"
                                        Click="Scrcpy_Click" Style="{StaticResource MacBtnPrimary}"
                                        Padding="18,10" FontSize="13" HorizontalAlignment="Stretch"/>
