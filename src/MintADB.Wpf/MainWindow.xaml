<Window x:Class="MintADB.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MintADB"
        Icon="/exe.ico"
        Height="820" Width="1080"
        MinHeight="660" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <!-- macOS window shell — radius synced with WindowRoundHelper (26px) -->
    <Border x:Name="ShellRoot"
            Background="{StaticResource MacWindowBrush}"
            BorderBrush="#555558" BorderThickness="1.5"
            CornerRadius="{StaticResource MacRadiusWindow}"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource MacSidebarBrush}"
                    BorderBrush="{StaticResource MacSeparatorBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="26,26,0,0" ClipToBounds="True"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Button x:Name="BtnClose" Style="{StaticResource TrafficLight}"
                                Background="#FF5F57" Click="BtnClose_Click" ToolTip="{DynamicResource Close}"/>
                        <Button x:Name="BtnMinimize" Style="{StaticResource TrafficLight}"
                                Background="#FEBC2E" Click="BtnMinimize_Click" ToolTip="{DynamicResource Minimize}"/>
                        <Button x:Name="BtnMaximize" Style="{StaticResource TrafficLight}"
                                Background="#28C840" Click="BtnMaximize_Click" ToolTip="{DynamicResource Maximize}"/>
                        <ComboBox x:Name="LanguageSelector" Width="70" Margin="20,0,0,0"
                                  SelectionChanged="LanguageSelector_SelectionChanged"
                                  ToolTip="{DynamicResource Language}">
                            <ComboBoxItem Content="VI" Tag="vi"/>
                            <ComboBoxItem Content="EN" Tag="en"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="MintADB" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource MacSecondaryBrightBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MINT_HD" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource MacSecondaryBrush}"
                                   HorizontalAlignment="Center" Opacity="0.85"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body — bottom corners rounded per column -->
            <Grid Grid.Row="1" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource MacSidebarBrush}"
                        CornerRadius="0,0,0,26" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,20,16,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="36" Height="36" CornerRadius="{StaticResource MacRadiusCard}"
                                    Background="Transparent" ClipToBounds="True">
                                <Image Source="/exe.ico" Width="36" Height="36" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="MintADB" FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="MINT_HD · Xiaomi Tools" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrightBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource MacTabBar}" Margin="0,0,0,14">
                            <Grid Style="{StaticResource MacTabStrip}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="NavOptimize" Grid.Column="0" Content="{DynamicResource NavOptimize}"
                                        Click="NavOptimize_Click"
                                        Tag="active"
                                        Style="{StaticResource MacNavBtn}"/>
                                <Button x:Name="NavTools" Grid.Column="1" Content="{DynamicResource NavTools}"
                                        Click="NavTools_Click"
                                        Style="{StaticResource MacNavBtn}"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource Device}" Style="{StaticResource MacGroupLabel}" Margin="0"/>
                            <Button Grid.Column="1" Content="↻" Click="RefreshDevices_Click"
                                    Style="{StaticResource MacBtnSecondary}"
                                    Padding="10,4" FontSize="12" Margin="0"
                                    ToolTip="{DynamicResource RefreshDeviceList}"/>
                        </Grid>

                        <ListBox x:Name="DeviceList" Style="{StaticResource MacDeviceList}"
                                 MaxHeight="160" SelectionChanged="DeviceList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ModelDisplay}"
                                                       FontSize="12" FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Serial}" FontSize="10"
                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="{StaticResource MacSecondaryBrightBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="{StaticResource MacRadiusPill}"
                                                Padding="7,3" Margin="6,0,0,0" VerticalAlignment="Center"
                                                Background="{Binding StateBadgeBackground}">
                                            <TextBlock Text="{Binding StateLabel}" FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding StateAccentColor}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock x:Name="NoDeviceText" Text="{DynamicResource NoDeviceHint}"
                                   FontSize="11" Foreground="{StaticResource MacSecondaryBrightBrush}"
                                   TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>
                        <TextBlock x:Name="DeviceHintText" Text=""
                                   FontSize="10" Foreground="#FFD060"
                                   TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <Border Grid.Row="1" Margin="16,0" Style="{StaticResource MacCard}"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DeviceInfo}" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource MacSecondaryBrightBrush}"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Fill="#636366"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectionLabel" Text="{DynamicResource Disconnected}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrightBrush}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Model}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrightBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceModelText" Grid.Column="1" Text="—"
                                           FontSize="12" FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ShowOnDisabled="True"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Serial}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrightBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceSerialText" Grid.Column="1" Text="—"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#9ECFFF"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ShowOnDisabled="True"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Status}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrightBrush}"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="DeviceStateBadge" Grid.Column="1"
                                        CornerRadius="{StaticResource MacRadiusPill}"
                                        Padding="8,4" HorizontalAlignment="Left"
                                        Background="#3A3A3C">
                                    <TextBlock x:Name="DeviceStateText" Text="{DynamicResource Disconnected}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#AEAEB2"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="16,12,16,16">
                        <TextBlock x:Name="AdbPathText" FontSize="10"
                                   Foreground="{StaticResource MacSecondaryBrightBrush}" Opacity="0.75"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource MacSeparatorBrush}"
                        Margin="0,0,0,26"/>

                <!-- Content -->
                <Border Grid.Column="2" Background="{StaticResource MacWindowBrush}"
                        CornerRadius="0,0,26,0" ClipToBounds="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="Transparent"
                              Padding="0,0,6,0">
                    <StackPanel Margin="28,24,28,32" MaxWidth="720">

                        <!-- ===== Tab: Optimize ===== -->
                        <StackPanel x:Name="PanelOptimize">

                        <TextBlock Text="{DynamicResource XiaomiChina}" Style="{StaticResource MacPageTitle}"/>
                        <TextBlock Text="{DynamicResource OptimizeSubtitle}"
                                   Style="{StaticResource MacPageSubtitle}"/>

                        <!-- ROM info -->
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,20">
                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource ROM}" VerticalAlignment="Center" Margin="16,0,12,0"
                                           Foreground="{StaticResource MacTextBrush}"/>
                                <TextBlock x:Name="RomInfoText" Grid.Column="1"
                                           Text="{DynamicResource NotScanned}" VerticalAlignment="Center"
                                           Foreground="{StaticResource MacSecondaryBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnScanRom" Grid.Column="2" Content="{DynamicResource Scan}"
                                        Click="ScanRom_Click"
                                        Style="{StaticResource MacBtnSecondary}"
                                        Margin="0,0,12,0" Padding="12,4" FontSize="12"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- System toggles -->
                        <TextBlock Text="{DynamicResource SystemOptions}" Style="{StaticResource MacGroupLabelWarn}"/>
                        <Border Style="{StaticResource MacGroupBoxWarn}" Margin="0,0,0,20">
                            <StackPanel>
                                <CheckBox x:Name="OptGlobal" Content="{DynamicResource DisableAndroidRestrictions}"
                                          Style="{StaticResource MacToggle}" IsChecked="True"/>
                                <Border Style="{StaticResource MacSeparator}"/>
                                <CheckBox x:Name="OptChina" Content="{DynamicResource UnlockXiaomiChinaControl}"
                                          Style="{StaticResource MacToggle}" IsChecked="True"/>
                                <Border Style="{StaticResource MacSeparator}"/>
                                <CheckBox x:Name="OptGrant" Content="{DynamicResource AutoGrantPermissions}"
                                          Style="{StaticResource MacToggle}" IsChecked="True"/>
                                <Border Style="{StaticResource MacSeparator}"/>
                                <CheckBox x:Name="OptMiuiOpt" Content="{DynamicResource DisableMIUIOptimization}"
                                          Style="{StaticResource MacToggle}"/>
                                <Border Style="{StaticResource MacSeparator}"/>
                                <CheckBox x:Name="OptRegion" Content="{DynamicResource ChangeRegionCNtoGlobal}"
                                          Style="{StaticResource MacToggle}"/>
                                <Border Style="{StaticResource MacSeparator}"/>
                                <CheckBox x:Name="OptAnalytics" Content="{DynamicResource DisableMIUIAnalytics}"
                                          Style="{StaticResource MacToggle}" IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Apps -->
                        <TextBlock Text="{DynamicResource Apps}" Style="{StaticResource MacGroupLabelSafe}"/>
                        <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,12" Padding="0">
                            <StackPanel>
                                <Border Style="{StaticResource MacTabBar}" Margin="12,10,12,8">
                                    <Grid Style="{StaticResource MacTabStrip}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="AppNavActive" Grid.Column="0" Content="{DynamicResource Installed}"
                                                Click="AppNavActive_Click"
                                                Tag="active"
                                                Style="{StaticResource MacToolNavBtn}"/>
                                        <Button x:Name="AppNavInactive" Grid.Column="1" Content="{DynamicResource Disabled}"
                                                Click="AppNavInactive_Click"
                                                Style="{StaticResource MacToolNavBtn}"/>
                                    </Grid>
                                </Border>

                                <TextBlock Margin="12,0,12,6" FontSize="10" FontWeight="SemiBold">
                                    <Run Foreground="#5DD68A" Text="● Play Store"/>
                                    <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                                    <Run Foreground="#7EC8FF" Text="● User"/>
                                    <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                                    <Run Foreground="#FF8A82" Text="● ROM Bloat"/>
                                    <Run Foreground="{StaticResource MacSecondaryBrightBrush}" Text="  ·  "/>
                                    <Run Foreground="#FFD060" Text="● System"/>
                                </TextBlock>

                                <StackPanel x:Name="AppPageActive">
                                <Border Style="{StaticResource MacInsetHeader}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="AppScanStatus"
                                                       Text="{DynamicResource NoDeviceHint}"
                                                       FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button x:Name="BtnScanApps" Content="{DynamicResource ScanApps}"
                                                        Click="ScanApps_Click"
                                                        Style="{StaticResource MacToolbarBtn}"/>
                                                <Button x:Name="BtnSelectAll" Content="{DynamicResource SelectAll}"
                                                        Click="SelectAllApps_Click"
                                                        Style="{StaticResource MacToolbarBtn}"/>
                                                <Button x:Name="BtnDeselectAll" Content="{DynamicResource DeselectAll}"
                                                        Click="DeselectAllApps_Click"
                                                        Style="{StaticResource MacToolbarBtn}"
                                                        Margin="0"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="AppSearchBox" Tag="{DynamicResource SearchByNameOrPackage}"
                                                      TextChanged="AppSearchBox_TextChanged"/>
                                            <ComboBox x:Name="CategoryFilter" Grid.Column="1" Margin="8,0,0,0"
                                                      SelectionChanged="CategoryFilter_SelectionChanged"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource MacSeparator}" Margin="0"/>

                                <ListBox x:Name="AppList" Style="{StaticResource MacAppList}"
                                         MaxHeight="360" Margin="8,6,8,4"
                                         SelectionMode="Single"
                                         PreviewMouseLeftButtonDown="AppList_PreviewMouseLeftButtonDown">
                                    <ListBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.ContainerStyle>
                                                <Style TargetType="GroupItem">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="GroupItem">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Style="{StaticResource MacAppGroupHeader}"/>
                                                                    <ItemsPresenter/>
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GroupStyle.ContainerStyle>
                                        </GroupStyle>
                                    </ListBox.GroupStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CategoryRowBackground}"
                                                    BorderBrush="{Binding CategoryRowBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource MacRadiusBtn}"
                                                    Padding="8,6" Margin="2,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{Binding CategoryAccentColor}"
                                                            CornerRadius="2" Margin="0,2,8,2"/>
                                                    <CheckBox Grid.Column="1" Style="{StaticResource MacAppCheck}"
                                                              IsChecked="{Binding Selected, Mode=TwoWay}"
                                                              Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Package}" FontSize="10"
                                                                   Foreground="{StaticResource MacSecondaryBrightBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <Border CornerRadius="{StaticResource MacRadiusPill}"
                                                                Padding="8,3"
                                                                Background="{Binding CategoryBadgeBackground}"
                                                                Margin="0,0,8,0">
                                                            <TextBlock Text="{Binding CategoryLabel}" FontSize="10"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding CategoryBadgeForeground}"/>
                                                        </Border>
                                                        <Button Content="{DynamicResource RemoveDisable}" Tag="{Binding}"
                                                                Click="RemoveSingleApp_Click"
                                                                Style="{StaticResource MacToolbarBtn}"
                                                                Padding="8,3" FontSize="10" Margin="0"
                                                                ToolTip="Remove app or disable if cannot remove"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Style="{StaticResource MacSeparator}" Margin="0,8,0,0"/>
                                <TextBox x:Name="CustomPackageBox" Margin="12,10,12,12"
                                         Tag="{DynamicResource CustomPackage}"/>
                                </StackPanel>

                                <StackPanel x:Name="AppPageInactive" Visibility="Collapsed">
                                    <Border Style="{StaticResource MacInsetHeader}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="InactiveAppScanStatus"
                                                           Text="{DynamicResource Scanning}"
                                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button x:Name="BtnScanInactiveApps" Content="{DynamicResource Scan}"
                                                            Click="ScanInactiveApps_Click"
                                                            Style="{StaticResource MacToolbarBtn}"/>
                                                    <Button x:Name="BtnSelectAllInactive" Content="{DynamicResource SelectAll}"
                                                            Click="SelectAllInactiveApps_Click"
                                                            Style="{StaticResource MacToolbarBtn}"/>
                                                    <Button x:Name="BtnDeselectAllInactive" Content="{DynamicResource DeselectAll}"
                                                            Click="DeselectAllInactiveApps_Click"
                                                            Style="{StaticResource MacToolbarBtn}"
                                                            Margin="0"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="130"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="InactiveAppSearchBox" Tag="{DynamicResource SearchByNameOrPackage}"
                                                         TextChanged="InactiveAppSearchBox_TextChanged"/>
                                                <ComboBox x:Name="InactiveStateFilter" Grid.Column="1" Margin="8,0,0,0"
                                                          SelectionChanged="InactiveStateFilter_SelectionChanged"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource MacSeparator}" Margin="0"/>

                                    <ListBox x:Name="InactiveAppList" Style="{StaticResource MacAppList}"
                                             MaxHeight="360" Margin="8,6,8,12"
                                             SelectionMode="Single"
                                             PreviewMouseLeftButtonDown="InactiveAppList_PreviewMouseLeftButtonDown">
                                        <ListBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.ContainerStyle>
                                                    <Style TargetType="GroupItem">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="GroupItem">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Style="{StaticResource MacInactiveGroupHeader}"/>
                                                                        <ItemsPresenter/>
                                                                    </StackPanel>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </GroupStyle.ContainerStyle>
                                            </GroupStyle>
                                        </ListBox.GroupStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StateRowBackground}"
                                                        BorderBrush="{Binding StateRowBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource MacRadiusBtn}"
                                                        Padding="8,6" Margin="2,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{Binding StateAccentColor}"
                                                                CornerRadius="2" Margin="0,2,8,2"/>
                                                        <CheckBox Grid.Column="1" Style="{StaticResource MacAppCheck}"
                                                                  IsChecked="{Binding Selected, Mode=TwoWay}"
                                                                  Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Package}" FontSize="10"
                                                                       Foreground="{StaticResource MacSecondaryBrightBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Border CornerRadius="{StaticResource MacRadiusPill}"
                                                                    Padding="8,3"
                                                                    Background="{Binding StateBadgeBackground}"
                                                                    Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding StateLabel}" FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding StateBadgeForeground}"/>
                                                            </Border>
                                                            <Button Content="{DynamicResource Restore}" Tag="{Binding}"
                                                                    Click="RestoreSingleInactiveApp_Click"
                                                                    Style="{StaticResource MacToolbarBtn}"
                                                                    Padding="8,3" FontSize="10" Margin="0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="AppActionActive">
                        <!-- Uninstall & Disable Apps -->
                        <TextBlock Text="{DynamicResource UninstallDisableApps}" Style="{StaticResource MacGroupLabelDanger}"/>
                        <Border Style="{StaticResource MacGroupBoxDanger}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource UninstallDisableAppsDesc}"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnRemoveOrDisable" Content="{DynamicResource UninstallDisable}"
                                            Click="RemoveOrDisable_Click"
                                            Style="{StaticResource MacBtnDestructive}"/>
                                    <Button x:Name="BtnUninstallSystemShell" Content="{DynamicResource UninstallSystemShell}"
                                            Click="UninstallSystemShell_Click"
                                            Style="{StaticResource MacBtnDestructive}"
                                            ToolTip="Remove system/ROM bloat via adb shell: pm uninstall --user 0 (no root needed)"/>
                                    <Button x:Name="BtnDisableApps" Content="{DynamicResource DisableApps}"
                                            Click="DisableApps_Click"
                                            Style="{StaticResource MacBtnSecondary}"/>
                                    <Button x:Name="BtnUninstallAllBloat" Content="{DynamicResource UninstallAllBloat}"
                                            Click="UninstallAllBloat_Click"
                                            Style="{StaticResource MacBtnDestructive}"
                                            Margin="0"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>

                        <StackPanel x:Name="AppActionInactive" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource RestoreApps}" Style="{StaticResource MacGroupLabelSafe}"/>
                        <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource RestoreAppsDesc}"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnRestoreInactiveApps" Content="{DynamicResource RestoreSelected}"
                                            Click="RestoreInactiveApps_Click"
                                            Style="{StaticResource MacBtnPrimary}"/>
                                    <Button x:Name="BtnEnableApps" Content="{DynamicResource EnableSelected}"
                                            Click="EnableInactiveApps_Click"
