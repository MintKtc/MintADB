                                                Style="{StaticResource MacToolBtn}" Background="#E65100"
                                                HorizontalAlignment="Stretch"
                                                Click="ToolFixNotifications_Click"
                                                ToolTip="Fix notifications + grant permissions + disable battery optimization"/>
                                        <Button Grid.Row="2" Grid.Column="2" x:Name="BtnToolDisableBattery" Content="{DynamicResource DisableBatteryOptimization}"
                                                Style="{StaticResource MacToolBtn}" Background="#5D4037"
