                                <TextBlock Text="Flash nhanh (dùng file đã chọn ở trên)" FontSize="10"
                                           Foreground="{StaticResource MacSecondaryBrush}" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <Button x:Name="BtnFastbootFlashBoot" Content="boot"
                                            Click="FastbootFlashBoot_Click" Style="{StaticResource MacToolbarBtn}"/>
                                    <Button x:Name="BtnFastbootFlashRecovery" Content="recovery"
                                            Click="FastbootFlashRecovery_Click" Style="{StaticResource MacToolbarBtn}"/>
                                    <Button x:Name="BtnFastbootFlashVendorBoot" Content="vendor_boot"
                                            Click="FastbootFlashVendorBoot_Click" Style="{StaticResource MacToolbarBtn}"/>
                                    <Button x:Name="BtnFastbootFlashVbmeta" Content="vbmeta"
                                            Click="FastbootFlashVbmeta_Click" Style="{StaticResource MacToolbarBtn}"
                                            Margin="0"/>
                                </WrapPanel>
                                <TextBlock FontSize="10" Margin="0,10,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource MacSecondaryBrush}">
                                    <Run Text="Máy phải ở chế độ Fastboot (khóa bootloader mở). "/>
                                    <Run Text="vbmeta" FontWeight="SemiBold"/>
                                    <Run Text=" — thêm «--disable-verity --disable-verification» nếu cần (chạy tay trong terminal)."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        </StackPanel>

