                                            Click="ClearAdDns_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnCheckAdDns" Content="{DynamicResource CheckDNS}"
                                            Click="CheckAdDns_Click" Style="{StaticResource MacToolBtn}"/>
