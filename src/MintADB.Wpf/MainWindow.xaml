                                                                        <Setter Property="Background" Value="#1A3A5C"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="AppOp">
                                                                                <Setter Property="Background" Value="#3D2A4A"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="Miui">
                                                                                <Setter Property="Background" Value="#3D3018"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Kind}" Value="Shizuku">
                                                                                <Setter Property="Background" Value="#2E3A4E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding KindLabel}" FontSize="9"
                                                                           FontWeight="SemiBold" Foreground="#7EC8FF">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#7EC8FF"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Kind}" Value="AppOp">
                                                                                    <Setter Property="Foreground" Value="#CE93D8"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Kind}" Value="Miui">
                                                                                    <Setter Property="Foreground" Value="#FFD060"/>
                                                                                </DataTrigger>
