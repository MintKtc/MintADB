                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button x:Name="BtnToolPresetShizuku" Content="{DynamicResource ShizukuPreset}"
