                                <ListBox x:Name="FastbootDeviceList"
                                         Style="{StaticResource MacFastbootDeviceList}"
                                         SelectionChanged="FastbootDeviceList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="FastbootPathText" FontSize="10" Margin="0,8,0,0"
                                           Foreground="{StaticResource MacSecondaryBrush}"/>
