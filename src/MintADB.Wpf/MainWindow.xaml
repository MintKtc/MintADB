                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding CategoryBadgeForeground}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

