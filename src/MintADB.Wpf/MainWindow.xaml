                                            <TextBlock x:Name="BatteryCapacityLine" Text="Capacity: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="BatteryMaxCapacityLine" Text="Max capacity: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="BatteryStatusLine" Text="Status: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"/>
