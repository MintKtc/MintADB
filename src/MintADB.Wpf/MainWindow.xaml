                                <TextBlock Text="Điều khiển màn hình mượt — H.264, tối đa 120 FPS"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>
