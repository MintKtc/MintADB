                        <TextBlock Text="Shizuku" Style="{StaticResource MacGroupLabelInfo}"/>
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Shizuku cho phép app chạy lệnh hệ thống qua ADB — cần cài app và mở một lần trước khi khởi động."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <TextBlock x:Name="ShizukuStatusText" Text="Chưa kiểm tra"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnCheckShizuku" Content="Kiểm tra"
                                            Click="CheckShizuku_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnStartShizuku" Content="Khởi động Shizuku"
                                            Click="StartShizuku_Click" Style="{StaticResource MacToolBtn}"/>
                                    <Button x:Name="BtnOpenShizuku" Content="Mở app Shizuku"
                                            Click="OpenShizuku_Click" Style="{StaticResource MacToolBtn}"/>
