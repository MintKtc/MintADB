                                                                            <Setter Property="Background" Value="#2A406A"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter Property="Background" Value="#0E1A30"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                    </Button.Style>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto" Padding="8,6">
                                        <ItemsControl x:Name="ToolPermissionList">
                                            <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.ContainerStyle>
                                                        <Style TargetType="GroupItem">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="GroupItem">
                                                                        <Border CornerRadius="{StaticResource MacRadiusCard}" Background="#2A2A2A"
                                                                                BorderBrush="#484848" BorderThickness="1"
                                                                                Padding="10,8" Margin="0,0,0,8">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           FontSize="13" FontWeight="Bold"
                                                                                           Foreground="#7EC8FF" Margin="0,0,0,6"/>
                                                                                <ItemsPresenter/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </GroupStyle.ContainerStyle>
                                                </GroupStyle>
                                            </ItemsControl.GroupStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="{StaticResource MacRadiusBtn}" Background="#323232" Padding="10,8"
                                                            Margin="0,0,0,6" BorderBrush="#484848" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
