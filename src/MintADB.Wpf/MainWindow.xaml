                                </Grid>
                            </Grid>
                        </Border>

                        </StackPanel>

                        <!-- ── Scrcpy ── -->
                        <StackPanel x:Name="ToolPageScreen" Visibility="Collapsed">

                        <TextBlock Text="{DynamicResource Scrcpy}" Style="{StaticResource MacGroupLabelInfo}"/>
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,16" Padding="14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ScrcpyDesc}"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>
