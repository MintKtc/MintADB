                                                BorderBrush="#0A84FF" BorderThickness="3"
                                                Background="#323232" Margin="0,0,20,0">
                                            <Grid>
                                                <Border Height="14" VerticalAlignment="Top"
                                                        Background="#323232" HorizontalAlignment="Center"
                                                        Width="36" CornerRadius="0,0,8,8" Margin="0,-3,0,0"/>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="DisplayResBig" Text="—×—"
                                                               FontSize="11" TextAlignment="Center"
                                                               Foreground="{StaticResource MacSecondaryBrush}"/>
                                                    <TextBlock x:Name="DisplayHzBig" Text="— Hz"
                                                               FontSize="22" FontWeight="Bold"
                                                               Foreground="#64B5F6" TextAlignment="Center"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Border x:Name="DisplayPanelBadge" Background="#2A2A2A"
                                                    CornerRadius="{StaticResource MacRadiusPill}"
                                                    Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock x:Name="DisplayPanelText" Text="Panel"
                                                           FontSize="15" FontWeight="SemiBold" Foreground="#64B5F6"/>
                                            </Border>
                                            <TextBlock x:Name="DisplayPanelDetailLine" Text="Panel: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="DisplayDpiLine" Text="DPI: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="DisplayHzLine" Text="Refresh Rate: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button x:Name="BtnLoadDisplayInfo" Content="{DynamicResource ReadDisplayInfo}"
                                            Click="LoadDisplayInfo_Click" Style="{StaticResource MacToolBtn}"
                                            HorizontalAlignment="Left" Margin="0,0,0,10"/>
                                    <TextBox x:Name="DisplayInfoText" IsReadOnly="True" TextWrapping="Wrap"
                                             MinHeight="100" VerticalScrollBarVisibility="Auto"
                                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                             Text="Tap «Read Display Info»"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{DynamicResource LockHz}" Style="{StaticResource MacGroupLabelSafe}" Margin="0,8,0,0"/>
                            <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,16" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LockHzDesc}"
                                               FontSize="10" Foreground="#5DD68A" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource LockAt}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="HzLockPreset" Grid.Column="1" SelectedIndex="2">
                                            <ComboBoxItem Content="60 Hz (battery saver)"/>
                                            <ComboBoxItem Content="90 Hz"/>
                                            <ComboBoxItem Content="120 Hz (recommended)"/>
                                            <ComboBoxItem Content="144 Hz"/>
