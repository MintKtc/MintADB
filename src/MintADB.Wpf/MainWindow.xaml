                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="14" FontWeight="Bold"
                                                                           Foreground="{StaticResource MacTextBrush}"/>
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="11" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource MacSecondaryBrightBrush}"
                                                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                <TextBlock FontSize="10" Foreground="#9ECFFF"
                                                                           FontFamily="Cascadia Mono, Consolas, monospace" Margin="0,4,0,0">
                                                                    <Run Text="{Binding KindLabel, Mode=OneWay}"/>
                                                                    <Run Text=" · "/>
                                                                    <Run Text="{Binding TechnicalName, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <Border Grid.Column="2" CornerRadius="{StaticResource MacRadiusSm}" Padding="6,3"
                                                                    VerticalAlignment="Top" Margin="6,0,0,0">
