                                                                            <Setter Property="Background" Value="#6E2828"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter Property="Background" Value="#2E1010"/>
                                                                        </Trigger>
