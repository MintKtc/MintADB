                                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                             Text="Tap «Read Hz» to view current peak/min/adaptive"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="SysPageDevice" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource DeviceInfoTitle}" Style="{StaticResource MacGroupLabelWarn}"/>
                            <Border Style="{StaticResource MacGroupBoxWarn}" Margin="0,0,0,24" Padding="14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="88" Height="156" CornerRadius="18"
                                                BorderBrush="#FF9800" BorderThickness="3"
                                                Background="#323232" Margin="0,0,20,0">
                                            <Grid>
                                                <Border Height="14" VerticalAlignment="Top"
                                                        Background="#323232" HorizontalAlignment="Center"
                                                        Width="36" CornerRadius="0,0,8,8" Margin="0,-3,0,0"/>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="DeviceBrandGlyph" Text="—"
                                                               FontSize="24" FontWeight="Bold"
                                                               TextAlignment="Center" Foreground="#E65100"
                                                               Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="DeviceCodenameLine" Text="—"
                                                               FontSize="10" TextAlignment="Center"
                                                               Foreground="{StaticResource MacSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="DeviceBrandBig" Text="—"
                                                       FontSize="28" FontWeight="Bold" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="DeviceModelLine" Text="Model: —"
                                                       FontSize="13" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock x:Name="DeviceAndroidBig" Text="Android —"
                                                       FontSize="22" FontWeight="SemiBold"
                                                       Foreground="#E65100" Margin="0,0,0,8"/>
                                            <Border x:Name="DeviceOsBadge" Background="#3D3018"
                                                    CornerRadius="{StaticResource MacRadiusPill}"
                                                    Padding="12,6" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <TextBlock x:Name="DeviceOsText" Text="OS"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#E65100"/>
                                            </Border>
                                            <TextBlock x:Name="DeviceRomLine" Text="ROM: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="DeviceBuildLine" Text="Build: —"
                                                       FontSize="12" Foreground="{StaticResource MacSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button x:Name="BtnLoadDeviceInfo" Content="{DynamicResource ReadDisplayInfo}"
                                            Click="LoadDeviceInfo_Click" Style="{StaticResource MacToolBtn}"
                                            HorizontalAlignment="Left" Margin="0,0,0,10"/>
                                    <TextBox x:Name="SysDeviceInfoText" IsReadOnly="True" TextWrapping="Wrap"
                                             MinHeight="120" VerticalScrollBarVisibility="Auto"
                                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                             Text="Tap «Read Device Info»"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Storage Info -->
                        <TextBlock Text="Storage" Style="{StaticResource MacGroupLabelInfo}" Margin="0,8,0,0"/>
