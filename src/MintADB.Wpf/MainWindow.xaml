                                                HorizontalAlignment="Stretch"
                                                Click="ToolFixNotifications_Click"
                                                ToolTip="Fix thông báo + cấp quyền + tắt pin"/>
                                        <Button Grid.Row="2" Grid.Column="2" x:Name="BtnToolDisableBattery" Content="Tắt tối ưu pin"
                                                Style="{StaticResource MacToolBtn}" Background="#5D4037"
                                                HorizontalAlignment="Stretch"
                                                Click="ToolDisableBattery_Click"/>
                                        <Button Grid.Row="2" Grid.Column="4" x:Name="BtnToolApplyAll" Content="Áp dụng tất cả"
                                                Style="{StaticResource MacToolBtn}" Background="#C62828"
                                                HorizontalAlignment="Stretch"
                                                Click="ToolApplyAll_Click"
                                                ToolTip="Cấp quyền + thông báo + pin cho app đã chọn"/>
                                    </Grid>
                                    <Grid Grid.Row="2" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" x:Name="BtnSelectAllToolPerms" Content="Chọn tất cả quyền"
