                                           Foreground="{StaticResource MacBlueBrush}"
                                           Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Reboot (fastboot)" Style="{StaticResource MacGroupLabelDanger}"/>
                        <Border Style="{StaticResource MacGroupBoxDanger}" Margin="0,0,0,16" Padding="12">
                            <WrapPanel>
                                <Button x:Name="BtnFastbootReboot" Content="Reboot"
                                        Click="FastbootReboot_Click" Style="{StaticResource MacToolBtn}"/>
                                <Button x:Name="BtnFastbootRebootBootloader" Content="Bootloader"
                                        Click="FastbootRebootBootloader_Click" Style="{StaticResource MacToolBtn}"/>
                                <Button x:Name="BtnFastbootRebootRecovery" Content="Recovery"
                                        Click="FastbootRebootRecovery_Click" Style="{StaticResource MacToolBtn}"/>
                                <Button x:Name="BtnFastbootRebootFastbootd" Content="Fastbootd"
                                        Click="FastbootRebootFastbootd_Click" Style="{StaticResource MacToolBtn}"/>
                                <Button x:Name="BtnFastbootContinue" Content="Continue"
                                        Click="FastbootContinue_Click" Style="{StaticResource MacToolBtn}"
                                        ToolTip="Tiếp tục boot sau khi flash"/>
                                <Button x:Name="BtnFastbootOemEdl" Content="OEM EDL"
                                        Click="FastbootOemEdl_Click" Style="{StaticResource MacBtnSecondary}"
                                        ToolTip="Xiaomi — fastboot oem edl"/>
                            </WrapPanel>
                        </Border>

                        <TextBlock Text="Flash image" Style="{StaticResource MacGroupLabelWarn}"/>
                        <Border Style="{StaticResource MacGroupBoxWarn}" Margin="0,0,0,16" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Partition" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource MacSecondaryBrush}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="FastbootPartitionCombo" IsEditable="True" Margin="0,0,0,10">
                                    <ComboBoxItem Content="boot" IsSelected="True"/>
                                    <ComboBoxItem Content="init_boot"/>
                                    <ComboBoxItem Content="recovery"/>
                                    <ComboBoxItem Content="vendor_boot"/>
                                    <ComboBoxItem Content="vbmeta"/>
                                    <ComboBoxItem Content="dtbo"/>
                                    <ComboBoxItem Content="system"/>
                                    <ComboBoxItem Content="vendor"/>
                                    <ComboBoxItem Content="product"/>
                                    <ComboBoxItem Content="boot_a"/>
                                    <ComboBoxItem Content="boot_b"/>
                                </ComboBox>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FastbootImageBox" Tag="Đường dẫn file .img"/>
                                    <Button x:Name="BtnBrowseFastbootImage" Grid.Column="1" Content="Chọn file"
                                            Click="BrowseFastbootImage_Click" Style="{StaticResource MacToolBtn}"
                                            Margin="8,0,0,0" MinWidth="90"/>
                                </Grid>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button x:Name="BtnFastbootFlash" Content="Flash"
                                            Click="FastbootFlash_Click" Style="{StaticResource MacBtnPrimary}"
                                            MinWidth="100"/>
