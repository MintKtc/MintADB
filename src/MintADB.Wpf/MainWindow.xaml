                            <UniformGrid Columns="5">
                                <Button x:Name="BtnReboot" Content="{DynamicResource Reboot}" Click="Reboot_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                <Button x:Name="BtnRebootRecovery" Content="{DynamicResource Recovery}" Click="RebootRecovery_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                <Button x:Name="BtnRebootBootloader" Content="{DynamicResource Bootloader}" Click="RebootBootloader_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                <Button x:Name="BtnRebootSideload" Content="{DynamicResource Sideload}" Click="RebootSideload_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
