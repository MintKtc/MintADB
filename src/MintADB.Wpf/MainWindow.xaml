                        </Border>

                        </StackPanel>

                        <!-- ── Tweaks ── -->
                        <StackPanel x:Name="ToolPageTweaks" Visibility="Collapsed">

                        <TextBlock Text="{DynamicResource SystemTweaksTitle}" Style="{StaticResource MacPageTitle}"/>
                        <TextBlock Text="{DynamicResource SystemTweaksSubtitle}"
                                   Style="{StaticResource MacPageSubtitle}" Margin="0,4,0,14"/>

                        <!-- DPI -->
                        <TextBlock Text="{DynamicResource ScreenDpiTitle}" Style="{StaticResource MacGroupLabelInfo}"/>
                        <Border Style="{StaticResource MacGroupBoxInfo}" Margin="0,0,0,12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource DpiDesc}"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DensityStatusText" Text="{DynamicResource TapReadHint}"
                                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11"
                                           Foreground="{StaticResource MacBlueBrush}" Margin="0,0,0,10"/>

                                <!-- Preset buttons -->
                                <TextBlock Text="{DynamicResource QuickSelect}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <UniformGrid Columns="6" Margin="0,0,0,10">
                                    <Button Content="320" Tag="320" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                    <Button Content="360" Tag="360" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                    <Button Content="400" Tag="400" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                    <Button Content="440" Tag="440" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                    <Button Content="480" Tag="480" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                    <Button Content="560" Tag="560" Click="DensityPreset_Click"
                                            Style="{StaticResource MacToolbarBtn}" MinWidth="70" Margin="0,0,4,4"/>
                                </UniformGrid>

                                <!-- Custom input -->
                                <TextBlock Text="{DynamicResource OrCustom}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DensityCustomBox" Grid.Column="0" Tag="440"
                                             Margin="0,0,8,0"/>
                                    <Button x:Name="BtnApplyDensity" Grid.Column="1" Content="{DynamicResource Apply}"
                                            Click="ApplyDensity_Click" Style="{StaticResource MacToolbarBtn}"
                                            MinWidth="90"/>
                                </Grid>

                                <!-- Action buttons -->
                                <UniformGrid Columns="2">
                                    <Button x:Name="BtnReadDensity" Content="{DynamicResource Read}"
                                            Click="ReadDensity_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnResetDensity" Content="{DynamicResource ResetBtn}"
                                            Click="ResetDensity_Click" Style="{StaticResource MacToolBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>
                            </StackPanel>
