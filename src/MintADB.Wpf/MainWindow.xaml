                                            <Border CornerRadius="6" Padding="10,8"
                                                    Background="#323232" BorderBrush="#484848" BorderThickness="1" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="40" Height="40" CornerRadius="12"
                                                            VerticalAlignment="Center" Margin="0,0,10,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding IconBackground}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding IconEmoji}"
                                                                   FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding SizeText}" FontSize="10"
                                                                   Foreground="{StaticResource MacSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="{DynamicResource Push}" Tag="{Binding}" Click="PushBundledApk_Click"
                                                                Focusable="False" Style="{StaticResource MacToolbarBtn}"
                                                                MinWidth="50" Padding="6,4" FontSize="10" Margin="0,0,4,0"/>
                                                        <Button Content="{DynamicResource Install}" Tag="{Binding}" Click="InstallBundledApk_Click"
                                                                Focusable="False" Style="{StaticResource MacToolbarBtn}"
                                                                MinWidth="50" Padding="6,4" FontSize="10"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock x:Name="BundledApkDirText" FontSize="10" Margin="0,4,0,0"
                                           Foreground="{StaticResource MacSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
