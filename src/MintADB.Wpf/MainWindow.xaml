                            <StackPanel>
                                <TextBlock Text="{DynamicResource PushDesc}"
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
