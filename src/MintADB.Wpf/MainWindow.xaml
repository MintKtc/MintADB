                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button x:Name="BtnToolPresetMiuiAutostart" Content="MIUI Lock"
