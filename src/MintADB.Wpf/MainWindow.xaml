                        </Border>

                        <StackPanel x:Name="SysPageBattery">
                            <TextBlock Text="{DynamicResource BatteryInfo}" Style="{StaticResource MacGroupLabelSafe}"/>
                            <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,24" Padding="14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel HorizontalAlignment="Center" Margin="0,0,20,0">
                                            <Border Width="30" Height="10" CornerRadius="4,4,0,0"
                                                    Background="#A5D6A7" HorizontalAlignment="Center" Margin="0,0,0,2"/>
