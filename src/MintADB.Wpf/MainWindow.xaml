                                <UniformGrid Columns="1">
                                    <Button x:Name="BtnLoadTouchInfo" Content="{DynamicResource ReadDisplayInfo}"
                                            Click="LoadTouchInfo_Click" Style="{StaticResource MacToolbarBtn}" MinWidth="150"/>
                                </UniformGrid>
