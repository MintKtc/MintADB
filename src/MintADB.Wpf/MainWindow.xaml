                                        <Button Grid.Row="2" Grid.Column="4" x:Name="BtnToolApplyAll" Content="{DynamicResource ApplyAll}"
                                                Style="{StaticResource MacToolBtn}" Background="#C62828"
                                                HorizontalAlignment="Stretch"
                                                Click="ToolApplyAll_Click"
                                                ToolTip="Grant permissions + notifications + battery for selected apps"/>
                                    </Grid>
                                    <Grid Grid.Row="2" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" x:Name="BtnSelectAllToolPerms" Content="{DynamicResource SelectAllPermissions}"
                                                Style="{StaticResource MacToolBtn}" Background="#37474F"
                                                HorizontalAlignment="Stretch" Margin="0,0,0,0"
                                                Click="SelectAllToolPermissions_Click"/>
                                        <Button Grid.Column="2" x:Name="BtnDeselectAllToolPerms" Content="{DynamicResource DeselectAllPermissions}"
                                                Style="{StaticResource MacToolBtn}" Background="#37474F"
                                                HorizontalAlignment="Stretch" Margin="0"
