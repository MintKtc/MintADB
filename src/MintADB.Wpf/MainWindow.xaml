                                        Style="{StaticResource MacToolNavBtn}"/>
                                <Button x:Name="SysNavDevice" Grid.Column="2" Content="{DynamicResource DeviceInfoTitle}"
                                        Click="SysNavDevice_Click"
                                        Style="{StaticResource MacToolNavBtn}"/>
