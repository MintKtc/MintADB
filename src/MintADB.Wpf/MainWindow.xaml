                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="260"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="1.2*" MinWidth="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Danh sách app -->
                            <Border Grid.Column="0" Style="{StaticResource MacGroupBoxSafe}" Padding="0" ClipToBounds="True"
                                    CornerRadius="{StaticResource MacRadiusGroup}">
                                <StackPanel>
                                    <Border Background="#1C2A22" Padding="12,10" Style="{StaticResource MacPanelHeader}">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource ToolsApps}" FontSize="14" FontWeight="SemiBold"/>
