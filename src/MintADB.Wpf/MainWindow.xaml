                                    <Button x:Name="BtnInstallApk" Content="{DynamicResource InstallAPK}" Click="InstallApk_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnBackupApk" Content="{DynamicResource BackupAPK}" Click="BackupApk_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnLaunchApp" Content="{DynamicResource OpenApp}" Click="LaunchApp_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"/>
                                </UniformGrid>
                                <UniformGrid Columns="3">
                                    <Button x:Name="BtnClearData" Content="{DynamicResource ClearData1App}" Click="ClearAppData_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnForceStop" Content="{DynamicResource ForceStop1App}" Click="ForceStopApps_Click" Style="{StaticResource MacToolbarBtn}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnBatchClearData" Content="{DynamicResource ClearDataMultiple}" Click="BatchClearData_Click" Style="{StaticResource MacToolbarBtn}" Margin="4,0,0,0"
                                            ToolTip="Select multiple apps in the list"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{DynamicResource PushPullFileExplorer}" Style="{StaticResource MacGroupLabelInfo}"/>
