                                                Click="SelectAllToolPermissions_Click"/>
                                        <Button Grid.Column="2" x:Name="BtnDeselectAllToolPerms" Content="Bỏ chọn tất cả"
                                                Style="{StaticResource MacToolBtn}" Background="#37474F"
                                                HorizontalAlignment="Stretch" Margin="0"
                                                Click="DeselectAllToolPermissions_Click"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

