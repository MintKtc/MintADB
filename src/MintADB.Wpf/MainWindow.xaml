                                    <Button x:Name="BtnRevokeShizukuPerm" Content="Revoke quyền"
                                            Click="RevokeShizukuPerm_Click" Style="{StaticResource MacToolBtn}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="AppOps (Shizuku / ADB)" Style="{StaticResource MacGroupLabelSafe}"/>
                        <Border Style="{StaticResource MacGroupBoxSafe}" Margin="0,0,0,24" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Các quyền đặc biệt thường cấp qua Shizuku hoặc ADB shell."
                                           FontSize="11" Foreground="{StaticResource MacSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button x:Name="BtnShizukuUsageStats" Content="Thống kê sử dụng"
