<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- macOS Sonoma Dark -->
    <Color x:Key="MacWindow">#1E1E1E</Color>
    <Color x:Key="MacSidebar">#282828</Color>
    <Color x:Key="MacGroup">#323232</Color>
    <Color x:Key="MacGroupHover">#3A3A3C</Color>
    <Color x:Key="MacSeparatorColor">#484848</Color>
    <Color x:Key="MacBlue">#0A84FF</Color>
    <Color x:Key="MacBluePressed">#0070E0</Color>
    <Color x:Key="MacText">#FFFFFF</Color>
    <Color x:Key="MacSecondary">#AEAEB2</Color>
    <Color x:Key="MacSecondaryBright">#D1D1D6</Color>
    <Color x:Key="MacTertiary">#636366</Color>
    <Color x:Key="MacGreen">#30D158</Color>
    <Color x:Key="MacRed">#FF453A</Color>
    <Color x:Key="MacOrange">#FF9F0A</Color>

    <SolidColorBrush x:Key="MacWindowBrush" Color="{StaticResource MacWindow}"/>
    <SolidColorBrush x:Key="MacSidebarBrush" Color="{StaticResource MacSidebar}"/>
    <SolidColorBrush x:Key="MacGroupBrush" Color="{StaticResource MacGroup}"/>
    <SolidColorBrush x:Key="MacSeparatorBrush" Color="{StaticResource MacSeparatorColor}"/>
    <SolidColorBrush x:Key="MacBlueBrush" Color="{StaticResource MacBlue}"/>
    <SolidColorBrush x:Key="MacTextBrush" Color="{StaticResource MacText}"/>
    <SolidColorBrush x:Key="MacSecondaryBrush" Color="{StaticResource MacSecondary}"/>
    <SolidColorBrush x:Key="MacSecondaryBrightBrush" Color="{StaticResource MacSecondaryBright}"/>
    <SolidColorBrush x:Key="MacGreenBrush" Color="{StaticResource MacGreen}"/>

    <CornerRadius x:Key="MacRadiusWindow">26</CornerRadius>
    <CornerRadius x:Key="MacRadiusGroup">16</CornerRadius>
    <CornerRadius x:Key="MacRadiusBtn">10</CornerRadius>
    <CornerRadius x:Key="MacRadiusInput">10</CornerRadius>
    <CornerRadius x:Key="MacRadiusCard">12</CornerRadius>
    <CornerRadius x:Key="MacRadiusPill">24</CornerRadius>
    <CornerRadius x:Key="MacRadiusSm">8</CornerRadius>
    <CornerRadius x:Key="MacRadiusTab">14</CornerRadius>

    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
    </Style>

    <!-- Traffic light button -->
    <Style x:Key="TrafficLight" TargetType="Button">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Ellipse x:Name="Dot" Fill="{TemplateBinding Background}"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Dot" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- macOS Toggle Switch -->
    <Style x:Key="MacToggle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Height="32" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0" VerticalAlignment="Center" Margin="16,0,12,0"/>
                        <Border x:Name="Track" Grid.Column="1" Width="44" Height="26"
                                CornerRadius="13" Margin="0,0,16,0"
                                Background="#39393D" VerticalAlignment="Center">
                            <Ellipse x:Name="Thumb" Width="22" Height="22"
                                     Fill="White" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource MacBlueBrush}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.92"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Grouped list container -->
    <Style x:Key="MacGroupBox" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MacGroupBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusGroup}"/>
        <Setter Property="BorderBrush" Value="#3A3A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- Risk-tinted group boxes -->
    <Style x:Key="MacGroupBoxSafe" TargetType="Border" BasedOn="{StaticResource MacGroupBox}">
        <Setter Property="Background" Value="#1C2A22"/>
        <Setter Property="BorderBrush" Value="#2D6B45"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style x:Key="MacGroupBoxInfo" TargetType="Border" BasedOn="{StaticResource MacGroupBox}">
        <Setter Property="Background" Value="#1A2533"/>
        <Setter Property="BorderBrush" Value="#2B5A7A"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style x:Key="MacGroupBoxWarn" TargetType="Border" BasedOn="{StaticResource MacGroupBox}">
        <Setter Property="Background" Value="#2A2418"/>
        <Setter Property="BorderBrush" Value="#8A6B1E"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style x:Key="MacGroupBoxDanger" TargetType="Border" BasedOn="{StaticResource MacGroupBox}">
        <Setter Property="Background" Value="#2A1C1C"/>
        <Setter Property="BorderBrush" Value="#8A3030"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style x:Key="MacCard" TargetType="Border" BasedOn="{StaticResource MacGroupBox}">
        <Setter Property="Background" Value="#323232"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusCard}"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style x:Key="MacInsetHeader" TargetType="Border">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="16,16,0,0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="MacPanelHeader" TargetType="Border">
        <Setter Property="Background" Value="#2A2A2A"/>
        <Setter Property="CornerRadius" Value="16,16,0,0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="MacPanelFooter" TargetType="Border">
        <Setter Property="Background" Value="#1C1C1E"/>
        <Setter Property="CornerRadius" Value="0,0,16,16"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="MacInnerCard" TargetType="Border">
        <Setter Property="Background" Value="#323232"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusCard}"/>
        <Setter Property="BorderBrush" Value="#484848"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="MacTabBar" TargetType="Border">
        <Setter Property="Background" Value="#252527"/>
        <Setter Property="BorderBrush" Value="#3A3A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusTab}"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="MacTabStrip" TargetType="Grid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="MacTabContent" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MacGroupBrush}"/>
        <Setter Property="BorderBrush" Value="#3A3A3C"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusGroup}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="MacTerminalBox" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusGroup}"/>
        <Setter Property="BorderBrush" Value="#484848"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="MacGroupLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource MacSecondaryBrightBrush}"/>
        <Setter Property="Margin" Value="4,0,0,6"/>
    </Style>

    <Style x:Key="MacGroupLabelSafe" TargetType="TextBlock" BasedOn="{StaticResource MacGroupLabel}">
        <Setter Property="Foreground" Value="#5DD68A"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="MacGroupLabelInfo" TargetType="TextBlock" BasedOn="{StaticResource MacGroupLabel}">
        <Setter Property="Foreground" Value="#7EC8FF"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="MacGroupLabelWarn" TargetType="TextBlock" BasedOn="{StaticResource MacGroupLabel}">
        <Setter Property="Foreground" Value="#FFD060"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="MacGroupLabelDanger" TargetType="TextBlock" BasedOn="{StaticResource MacGroupLabel}">
        <Setter Property="Foreground" Value="#FF8A82"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="MacRiskLegend" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource MacSecondaryBrightBrush}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style x:Key="MacPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
    </Style>

    <Style x:Key="MacPageSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource MacSecondaryBrightBrush}"/>
        <Setter Property="Margin" Value="0,4,0,20"/>
    </Style>

    <Style x:Key="MacCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource MacSecondaryBrightBrush}"/>
    </Style>

    <!-- macOS Blue Button -->
    <Style x:Key="MacBtnPrimary" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="{StaticResource MacBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MacRadiusBtn}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A94FF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0070E0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacBtnSecondary" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="#3A3A3C"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MacRadiusBtn}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2C2C2E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacBundledApkListItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacBundledApkList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource MacBundledApkListItem}"/>
    </Style>

    <Style x:Key="MacBtnDestructive" TargetType="Button" BasedOn="{StaticResource MacBtnPrimary}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Background" Value="#FF453A"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF6961"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar device list -->
    <Style x:Key="MacDeviceListItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="#3A3A3C" CornerRadius="{StaticResource MacRadiusCard}"
                            Padding="10,8" BorderThickness="1" BorderBrush="Transparent">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A3A5C"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#1F4570"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacDeviceList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource MacDeviceListItem}"/>
    </Style>

    <!-- App list row (Settings-style) -->
    <Style x:Key="MacGroupHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource MacSecondaryBrightBrush}"/>
        <Setter Property="Margin" Value="8,10,8,4"/>
    </Style>

    <!-- App scan group headers — colored by category -->
    <Style x:Key="MacAppGroupHeader" TargetType="TextBlock" BasedOn="{StaticResource MacGroupHeader}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Name}" Value="Play Store">
                <Setter Property="Foreground" Value="#5DD68A"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="User tự cài">
                <Setter Property="Foreground" Value="#7EC8FF"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="Rác ROM">
                <Setter Property="Foreground" Value="#FF8A82"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="Hệ thống">
                <Setter Property="Foreground" Value="#FFD060"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MacInactiveGroupHeader" TargetType="TextBlock" BasedOn="{StaticResource MacGroupHeader}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding Name}" Value="Đã gỡ">
                <Setter Property="Foreground" Value="#FF8A82"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="Đã tắt">
                <Setter Property="Foreground" Value="#FFD060"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Name}" Value="Đã ẩn">
                <Setter Property="Foreground" Value="#7EC8FF"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MacAppListItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Row" Background="Transparent" Padding="6,3"
                            CornerRadius="{StaticResource MacRadiusBtn}" Margin="6,1"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#383838"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#2E3D4F"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Row" Property="Background" Value="#354656"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacAppList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource MacAppListItem}"/>
    </Style>

    <Style x:Key="MacAppCheck" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Box" Width="18" Height="18" CornerRadius="{StaticResource MacRadiusSm}"
                            Background="#1C1C1E" BorderBrush="#636366" BorderThickness="1.5">
                        <TextBlock x:Name="Mark" Text="✓" FontSize="11" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource MacBlueBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                            <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacBadgeInstalled" TargetType="Border">
        <Setter Property="Background" Value="#1A3D2A"/>
        <Setter Property="CornerRadius" Value="{StaticResource MacRadiusPill}"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MacBadgeMissing" TargetType="Border" BasedOn="{StaticResource MacBadgeInstalled}">
        <Setter Property="Background" Value="#3A3A3C"/>
    </Style>

    <Style x:Key="MacToolbarBtn" TargetType="Button" BasedOn="{StaticResource MacBtnSecondary}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="MacFastbootDeviceList" TargetType="ListBox" BasedOn="{StaticResource MacDeviceList}">
        <Setter Property="MaxHeight" Value="100"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#484848"/>
        <Setter Property="Background" Value="#323232"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- Checkbox có nhãn — dark, không nền trắng khi focus -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box" Width="18" Height="18" CornerRadius="{StaticResource MacRadiusSm}"
                                Background="#1C1C1E" BorderBrush="#636366" BorderThickness="1.5"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="Mark" Text="✓" FontSize="11" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource MacBlueBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                            <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Segmented tabs — đồng đều, bo cong liền mạch trong MacTabBar -->
    <Style x:Key="MacSegmentBtn" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#AEAEB2"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="0"
                            CornerRadius="{StaticResource MacRadiusSm}"
                            Padding="{TemplateBinding Padding}"
                            Margin="1,0"
                            SnapsToDevicePixels="True">
                        <TextBlock x:Name="Label" Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                   MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="active">
                            <Setter TargetName="Bd" Property="Background" Value="#1A3A5C"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="Label" Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value=""/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value=""/>
                                <Condition Property="IsPressed" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#2C2C2E"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="active"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#1F4570"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="active"/>
                                <Condition Property="IsPressed" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#163352"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacNavBtn" TargetType="Button" BasedOn="{StaticResource MacSegmentBtn}"/>
    <Style x:Key="MacNavBtnActive" TargetType="Button" BasedOn="{StaticResource MacSegmentBtn}"/>

    <Style x:Key="MacToolBtn" TargetType="Button" BasedOn="{StaticResource MacBtnSecondary}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinWidth" Value="100"/>
    </Style>

    <Style x:Key="MacToolNavBtn" TargetType="Button" BasedOn="{StaticResource MacSegmentBtn}">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Foreground" Value="#D1D1D6"/>
    </Style>

    <Style x:Key="MacToolNavBtnActive" TargetType="Button" BasedOn="{StaticResource MacToolNavBtn}"/>

    <!-- TextBox macOS -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#1C1C1E"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="{StaticResource MacBlueBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MacRadiusInput}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MacLogBox" TargetType="RichTextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#E5E5EA"/>
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="IsDocumentEnabled" Value="True"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ComboBox dark template -->
    <Style TargetType="ComboBox">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="#3A3A3C"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MacSeparatorBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource MacRadiusInput}"/>
                        <Grid Margin="10,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <TextBlock Grid.Column="1" Text="▾" FontSize="10"
                                       Foreground="{StaticResource MacSecondaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                        <ToggleButton Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press" Background="Transparent" BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Fade">
                            <Border Background="#2C2C2E" BorderBrush="#484848"
                                    BorderThickness="1" CornerRadius="{StaticResource MacRadiusInput}"
                                    Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="200">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#636366"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource MacBlueBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" Margin="4,1"
                            CornerRadius="{StaticResource MacRadiusSm}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource MacBlueBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A3A5C"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator line in grouped list -->
    <Style x:Key="MacSeparator" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource MacSeparatorBrush}"/>
        <Setter Property="Margin" Value="16,0"/>
    </Style>

    <!-- Rounded thin scrollbar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#5A5A5C" CornerRadius="4" Margin="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="0,0,4,0"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Background" Value="#3A3A3C"/>
        <Setter Property="Foreground" Value="{StaticResource MacTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MacRadiusBtn}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2C2C2E"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>