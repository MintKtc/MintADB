# Build output
dist/
**/bin/
**/obj/

# Release: large .exe tracked via Git LFS (see .gitattributes)
# release/*.zip still ignored unless needed
release/*.zip
!release/README.md

# User / runtime data
DisplayHz/
DeviceSpoof/
Recordings/
# Runtime device captures (Desktop\MintADB\Screenshots) — keep docs/screenshots for README
/Screenshots/
**/Desktop/MintADB/Screenshots/
DisplayHzBackup.json

# Large bundled binaries (see docs/BUNDLED-ASSETS.md)
src/MintADB.Wpf/Miui/**/*.apk
src/MintADB.Wpf/PlatformTools/**
!src/MintADB.Wpf/PlatformTools/.gitkeep
src/MintADB.Wpf/Drivers/**
!src/MintADB.Wpf/Drivers/.gitkeep

# Python legacy (optional)
mintadb/__pycache__/
**/__pycache__/
*.pyc
.venv/
venv/

